# Server
PORT=8000
PUBLIC_BASE_URL=http://127.0.0.1:8000
NODE_ENV=development
ENABLE_TEST_CHECKOUT=true

# Stripe
# Use test keys while validating. For live sales, switch to live keys and live webhook secret.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
DELIVERY_ACCESS_SECRET=replace_with_a_long_random_secret

# Either set the Stripe Price ID from Stripe, or use the fallback inline price below.
STRIPE_PRICE_ID=
STRIPE_PRICE_ID_BUNDLE=
BUNDLE_PRICE_CENTS=5900
PRODUCT_CURRENCY=usd

# Optional Gemini build assistant for the paid client guide.
GEMINI_API_KEY=replace_me
GEMINI_MODEL=gemini-1.5-flash

# Email delivery
# EMAIL_DELIVERY_MODE=console logs the customer email for local testing.
# EMAIL_DELIVERY_MODE=smtp sends real email using the SMTP settings below.
EMAIL_DELIVERY_MODE=console
FROM_EMAIL="Luxury Furniture Blueprints <support@luxuryfurnitureblueprints.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Optional durable newsletter capture endpoint for production, e.g. Make/Zapier/Beehiiv/custom CRM webhook.
NEWSLETTER_WEBHOOK_URL=
